# just trying with source parameters , without lensed . From which we would get psi, which later can be used for best fit template


import bilby
from gwpy.timeseries import TimeSeries
import logging
import psutil



bilby.core.utils.log.setup_logger(log_level='INFO')
print(f"Initial RAM Usage: {psutil.virtual_memory().percent}%")


EVENT = 'B'




gps_time = 1265754805.00
file_h1 = '/content/H-H1_GWOSC_O3b_4KHZ_R1-1265754112-4096.hdf5'
file_l1 = '/content/L-L1_GWOSC_O3b_4KHZ_R1-1265754112-4096.hdf5'


# Keep duration to 4 seconds and sample rate to 2048 to prevent Colab from crashing
duration = 4.0
sampling_frequency = 2048


h1_ts = TimeSeries.read(file_h1, format='hdf5.gwosc').crop(gps_time-2, gps_time+2).resample(sampling_frequency)
l1_ts = TimeSeries.read(file_l1, format='hdf5.gwosc').crop(gps_time-2, gps_time+2).resample(sampling_frequency)


# Create Interferometer objects
ifos = bilby.gw.detector.InterferometerList(['H1', 'L1'])
ifos[0].set_strain_data_from_gwpy_timeseries(h1_ts)
ifos[1].set_strain_data_from_gwpy_timeseries(l1_ts)

# Set the frequency boundaries
for ifo in ifos:
    ifo.minimum_frequency = 20.0
    ifo.maximum_frequency = 448.0

print(f"RAM Usage after data load: {psutil.virtual_memory().percent}%")



waveform_generator = bilby.gw.WaveformGenerator(
    duration=duration,
    sampling_frequency=sampling_frequency,
    frequency_domain_source_model=bilby.gw.source.lal_binary_black_hole,
    parameter_conversion=bilby.gw.conversion.convert_to_lal_binary_black_hole_parameters,
    waveform_arguments=dict(waveform_approximant='IMRPhenomXPHM', reference_frequency=20.0)
)


#  PRIORS (What we are searching for)


# BBHPriorDict automatically generates priors for ALL 15 parameters!
# (masses, spins, RA, Dec, distance, inclination, and psi/polarization)
priors = bilby.gw.prior.BBHPriorDict()

#  restrict the search space for mass and time slightly
priors['chirp_mass'] = bilby.core.prior.Uniform(name='chirp_mass', minimum=50.0, maximum=150.0)
priors['mass_ratio'] = bilby.core.prior.Uniform(name='mass_ratio', minimum=0.125, maximum=1.0)
priors['geocent_time'] = bilby.core.prior.Uniform(name='geocent_time', minimum=gps_time - 0.1, maximum=gps_time + 0.1)

# We delete mass_1 and mass_2 because Bilby will search for chirp_mass and mass_ratio instead
del priors['mass_1'], priors['mass_2']


# RUN THE SAMPLER

likelihood = bilby.gw.likelihood.GravitationalWaveTransient(
    interferometers=ifos,
    waveform_generator=waveform_generator,
    priors=priors
)

print("\n--- STARTING BAYESIAN INFERENCE ---")
print("This will search for the 15 Source Parameters (including RA, Dec, Spins, and Psi).")

result = bilby.run_sampler(
    likelihood=likelihood,
    priors=priors,
    sampler='dynesty',
    nlive=200,       
    dlogz=2.0,        
    outdir=f'Source_PE_Event_{EVENT}',
    label=f'GW_Source_{EVENT}'
)

# Plot the corner plot for the main physical parameters
result.plot_corner(parameters=['chirp_mass', 'mass_ratio', 'luminosity_distance', 'ra', 'dec', 'psi'])
print(f"\nSUCCESS! Results saved in the folder: Source_PE_Event_{EVENT}")
