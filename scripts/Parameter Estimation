
import numpy as np
import bilby
from bilby.core.prior import Uniform
from gwpy.timeseries import TimeSeries
import h5py
import os


bilby.core.utils.log.setup_logger(log_level='WARNING')


EVENT = 'B'

gps_time = 1265754805.00
file_h1 = '/content/H-H1_GWOSC_O3b_4KHZ_R1-1265754112-4096.hdf5'
file_l1 = '/content/L-L1_GWOSC_O3b_4KHZ_R1-1265754112-4096.hdf5'
post_file = '/content/GW200214_223307-PYCBC-POSTERIOR-IMRPhenomXPHM.hdf'


with h5py.File(post_file, 'r') as f:
    samples = f['samples']
    # Find the index of the highest likelihood
    maxL_idx = np.argmax(samples['loglikelihood'][:])

    # Extract Redshift to convert Source Mass -> Detector Mass
    z = samples['redshift'][maxL_idx]
    maxL_m1 = samples['srcmass1'][maxL_idx] * (1 + z)
    maxL_m2 = samples['srcmass2'][maxL_idx] * (1 + z)

    # Extract exact timing and distance
    maxL_distance = samples['distance'][maxL_idx]
    maxL_phase = samples['coa_phase'][maxL_idx]
    maxL_delta_tc = samples['delta_tc'][maxL_idx]

    # Extract Spins and Angles
    maxL_a1 = samples['spin1_a'][maxL_idx]
    maxL_a2 = samples['spin2_a'][maxL_idx]
    maxL_tilt1 = samples['spin1_polar'][maxL_idx]
    maxL_tilt2 = samples['spin2_polar'][maxL_idx]

    # Extract Sky Location and Inclination
    maxL_theta_jn = samples['inclination'][maxL_idx]
    maxL_ra = samples['ra'][maxL_idx]
    maxL_dec = samples['dec'][maxL_idx]

print(f"-> Found MaxL Detector Masses: M1={maxL_m1:.2f}, M2={maxL_m2:.2f}")

# DEFINE THE WAVE-OPTICS AMPLIFICATION MODEL

def lal_bbh_wo_lensing(frequency_array, mass_1, mass_2, luminosity_distance, a_1, tilt_1,
                       phi_12, a_2, tilt_2, phi_jl, theta_jn, phase, a, b, k, phi_0,
                       b_prime, k_prime, phi_0_prime, f_0, psi, **kwargs):

    # 1. Generate the standard UNLENSED wave
    gr_waveform = bilby.gw.source.lal_binary_black_hole(
        frequency_array=frequency_array, mass_1=mass_1, mass_2=mass_2,
        luminosity_distance=luminosity_distance, a_1=a_1, tilt_1=tilt_1, phi_12=phi_12,
        a_2=a_2, tilt_2=tilt_2, phi_jl=phi_jl, theta_jn=theta_jn, phase=phase, psi=psi, **kwargs)

    if gr_waveform is None:
        return None

    # 2. Apply the Wave-Optics Lensing Math (A(f) amplification factor)
    amp_mod = a * (1 + b * (np.cos(2 * np.pi * frequency_array / f_0 + phi_0) * np.exp(-frequency_array * k)))
    phase_mod = np.exp(1j * b_prime * np.cos(2 * np.pi * frequency_array / f_0 + phi_0_prime) * np.exp(-frequency_array * k_prime))
    correction = amp_mod * phase_mod

    # 3. Return the LENSED wave
    return dict(plus=gr_waveform['plus'] * correction, cross=gr_waveform['cross'] * correction)


#  LOAD DATA INTO BILBY

duration = 4.0 # Keep this short (4s)
sampling_frequency = 2048 # Reduced from 4096 to speed up laptop processing


h1_ts = TimeSeries.read(file_h1, format='hdf5.gwosc').crop(gps_time-2, gps_time+2).resample(sampling_frequency)
l1_ts = TimeSeries.read(file_l1, format='hdf5.gwosc').crop(gps_time-2, gps_time+2).resample(sampling_frequency)


ifos = bilby.gw.detector.InterferometerList(['H1', 'L1'])
ifos[0].set_strain_data_from_gwpy_timeseries(h1_ts)
ifos[1].set_strain_data_from_gwpy_timeseries(l1_ts)

for ifo in ifos:
    ifo.minimum_frequency = 20.0
    ifo.maximum_frequency = 448.0 # Max freq set to avoid high-frequency noise


#  SET THE PRIORS


priors = bilby.core.prior.PriorDict()

# 1. FIXED SOURCE PARAMETERS (Mapped from HDF5 file keys)
priors['mass_1'] = maxL_m1
priors['mass_2'] = maxL_m2
priors['phase'] = maxL_phase
priors['geocent_time'] = gps_time + maxL_delta_tc # Trigger + offset
priors['a_1'] = maxL_a1
priors['a_2'] = maxL_a2
priors['tilt_1'] = maxL_tilt1
priors['tilt_2'] = maxL_tilt2
priors['phi_12'] = 0.0
priors['phi_jl'] = 0.0
priors['dec'] = maxL_dec
priors['ra'] = maxL_ra
priors['theta_jn'] = maxL_theta_jn
priors['luminosity_distance'] = maxL_distance

# 2. THE SEARCH PARAMETERS (Lensing properties + unknown Polarization)
# add psi as a Uniform search parameter with periodic boundaries (0 to 2pi)
priors['psi'] = 0
# Uniform(name='psi', minimum=0.0, maximum=2*np.pi, boundary='periodic', latex_label=r'$\psi$')

# Wave-Optics Micro-Lens Parameters
priors['b'] = Uniform(name='b', minimum=0.0, maximum=0.99, latex_label='$b$')
priors['f_0'] = Uniform(name='f_0', minimum=10.0, maximum=448.0, latex_label='$f_0$')
priors['phi_0'] = Uniform(name='phi_0', minimum=0.0, maximum=2*np.pi, boundary='periodic', latex_label=r'$\phi_0$')
priors['b_prime'] = Uniform(name='b_prime', minimum=0.0, maximum=0.99, latex_label="$b'$")
priors['phi_0_prime'] = Uniform(name='phi_0_prime', minimum=0.0, maximum=2*np.pi, boundary='periodic', latex_label=r"$\phi'_0$")

# Fixed Lens Damping Constants
priors['a'] = 1.0
priors['k'] = 0.0
priors['k_prime'] = 0.0


#  RUN THE SAMPLER

waveform_generator = bilby.gw.WaveformGenerator(
    duration=duration,
    sampling_frequency=sampling_frequency,
    frequency_domain_source_model=lal_bbh_wo_lensing,
    parameter_conversion=bilby.gw.conversion.convert_to_lal_binary_black_hole_parameters,
    waveform_arguments=dict(waveform_approximant='IMRPhenomXPHM', reference_frequency=20.0, catch_waveform_errors=True)
)

likelihood = bilby.gw.likelihood.GravitationalWaveTransient(
    interferometers=ifos, waveform_generator=waveform_generator, priors=priors
)

result = bilby.run_sampler(
    likelihood=likelihood,
    priors=priors,
    sampler='dynesty',
    nlive=250,
    dlogz=2.0,
    npool=2,
    outdir=f'Lensing_Result_Event_{EVENT}',
    label=f'GW_Lensing_{EVENT}'
)

# Plot the final Corner Plot for the search parameters
result.plot_corner(parameters=['b', 'f_0', 'b_prime', 'psi'])
print("output folder - Corner Plot!")
